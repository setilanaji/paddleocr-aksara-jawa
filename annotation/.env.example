# Copy this file to annotation/.env and fill in your public hostname.
# The .env file is gitignored — put personal infrastructure details there.
#
# For a local-only (no tunnel) setup, you don't need this file — Label Studio
# will serve on http://localhost:8080 with the default compose config.

# Public HTTPS URL Label Studio is reachable at (through the Cloudflare tunnel)
# LABEL_STUDIO_HOST=https://label.yourdomain.com

# Same URL, used for Django CSRF trust
# CSRF_TRUSTED_ORIGINS=https://label.yourdomain.com
