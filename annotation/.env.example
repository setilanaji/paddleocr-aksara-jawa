# Copy this file to annotation/.env and fill in the values below.
# The .env file is gitignored — put personal infrastructure details there.
#
# For a local-only (no tunnel, no cloud storage) setup, no values are required —
# Label Studio will serve on http://localhost:8080 with bind-mounted data/real/.

# ---- Label Studio tunnel (read by docker-compose.yml) ----
# Public HTTPS URL Label Studio is reachable at (through the Cloudflare tunnel).
# Must match the `hostname:` in annotation/cloudflared/config.yml.
# LABEL_STUDIO_HOST=https://label.yourdomain.com

# Same URL, used for Django CSRF trust. Must equal LABEL_STUDIO_HOST.
# CSRF_TRUSTED_ORIGINS=https://label.yourdomain.com

# ---- Cloudflare R2 image storage (read by rclone / annotation-r2-sync skill) ----
# Only needed if you're serving annotation images from R2 instead of the
# local data/real/ bind mount. See docs/annotation_guide.md for the one-time
# bucket + CORS + API-token setup.
#
# R2_ACCOUNT_ID is the 32-char hex shown on the R2 dashboard.
# R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY come from an "Account API token"
# scoped to this bucket with Object Read & Write permission — the secret is
# shown once at creation and cannot be re-displayed.
# R2_ENDPOINT is https:// + R2_ACCOUNT_ID + .r2.cloudflarestorage.com
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=aksara-jawa-images
# R2_ENDPOINT=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
